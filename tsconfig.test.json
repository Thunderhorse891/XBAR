{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".codex-test-dist",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "declaration": false,
    "sourceMap": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/store/xbarStoreLogic.ts",
    "src/types/xbar.ts",
    "src/lib/xbarRuntime.ts",
    "src/lib/xbarPhaseTwo.ts",
    "src/lib/xbarGrowth.ts",
    "src/vite-env.d.ts",
    "tests/**/*.ts"
  ]
}
