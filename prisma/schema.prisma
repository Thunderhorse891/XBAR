generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Horse {
  id          Int      @id @default(autoincrement())
  name        String
  birthDate   DateTime?
  gender      String
  color       String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
