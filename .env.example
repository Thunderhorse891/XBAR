# ─── Supabase (required for cloud mode) ──────────────────────────────────────
# Project URL and anon key from: supabase.com → project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Table and bucket names — match what you created in Supabase
VITE_SUPABASE_WORKSPACE_TABLE=workspace_snapshots
VITE_SUPABASE_RELATIONAL_SYNC=true
VITE_SUPABASE_SNAPSHOT_FALLBACK=true
VITE_SUPABASE_MEDIA_BUCKET=horse-media
VITE_SUPABASE_DOCUMENT_BUCKET=horse-documents

# ─── Server-side secrets (Vercel env vars only — never prefix these with VITE_) ─
# Service role key from: supabase.com → project → Settings → API → service_role
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe secret key from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret from: dashboard.stripe.com → Developers → Webhooks
# Register endpoint: https://your-app.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create one recurring price per tier, paste the price_... IDs
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...
STRIPE_PRICE_ID_RANCH_OPS=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...

# ─── App URLs (required for invite emails and Stripe return URLs) ─────────────
VITE_PUBLIC_APP_URL=https://your-app.vercel.app
VITE_API_BASE_URL=https://your-app.vercel.app

# ─── Stripe payment links (optional fallback when /api/stripe/checkout fails) ─
# Generate at: dashboard.stripe.com → Products → Payment links
VITE_STRIPE_PAYMENT_LINK_STARTER=
VITE_STRIPE_PAYMENT_LINK_PROFESSIONAL=
VITE_STRIPE_PAYMENT_LINK_RANCH_OPS=
VITE_STRIPE_PAYMENT_LINK_ENTERPRISE=
VITE_STRIPE_BILLING_PORTAL_URL=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Allow browser-local mode — data lives in localStorage only, lost on cache clear
VITE_ALLOW_LOCAL_MODE=false

# Facebook App ID for sale-listing share buttons (feature degrades gracefully without it)
VITE_FACEBOOK_APP_ID=

# Allow buyer-profile share links to resolve in local mode (dev/preview only)
VITE_PUBLIC_SHARE_LOCAL_PREVIEW=false

# ─── Observability ────────────────────────────────────────────────────────────
VITE_RUNTIME_MONITORING_ENABLED=true
VITE_RUNTIME_TELEMETRY_API_ENABLED=false
