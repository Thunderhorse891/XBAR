{
  "name": "xbar-ranch-ledger",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "predev": "node scripts/prepare-ocr-assets.mjs",
    "dev": "vite",
    "prebuild": "node scripts/prepare-ocr-assets.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run supabase:prepare && tsc -p tsconfig.test.json && node --test \".codex-test-dist/tests/*.test.js\" \"tests/api/*.test.mjs\"",
    "test:e2e": "playwright test",
    "build:local": "node scripts/build-local.mjs",
    "test:prod-smoke": "npm run build:local && playwright test --config=playwright.prod.config.ts",
    "supabase:prepare": "node scripts/prepare-supabase-schema.mjs",
    "mobile:sync": "npm run build && cap sync",
    "mobile:copy": "npm run build && cap copy",
    "mobile:add:ios": "cap add ios",
    "mobile:add:android": "cap add android",
    "mobile:open:ios": "cap open ios",
    "mobile:open:android": "cap open android",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/android": "8.3.0",
    "@capacitor/cli": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@capacitor/ios": "8.3.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@supabase/supabase-js": "2.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.6.205",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.78.0",
    "react-router-dom": "6.30.4",
    "sonner": "^2.0.7",
    "stripe": "21.0.1",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "7.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.58.2",
    "@tesseract.js-data/eng": "^1.0.0",
    "@types/node": "20.19.37",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  }
}
