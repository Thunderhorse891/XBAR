{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "package": {
    "productName": "XBAR Horse Management",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "XBAR Horse Management",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  }
}
